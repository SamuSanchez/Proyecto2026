<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ems.system.mapper.SysMenuMapper">

    <!--Ã¨Å½·Ã¥â€“Ã¥½â€œÃ¥â€°Ã§â€¨Ã¦Ë†·Ã¦â€°â‚¬Ã¦Å“â€°Ã¨§â€™Ã¨â€°²Ã§Å¡â€žÃ¨Å“Ã¥â€¢-->
    <select id="getMenuTree" resultType="com.ems.system.entity.SysMenu">
        SELECT
            t1.*
        FROM
            sys_menu t1
                LEFT JOIN sys_role_menu t2 ON t1.id = t2.menu_id
                LEFT JOIN sys_role t3 ON t2.role_id = t3.id
        WHERE
            t3.role_code IN 
        <foreach collection="roles" item="role" open="(" separator="," close=")">
            #{role}
        </foreach>
    </select>

    <!--Ã¦ ¹Ã¦®Ã¨§â€™Ã¨â€°²Obtener lista de menus-->
    <select id="getMenuUrlByRole" resultType="java.lang.String">
        SELECT
        t1.url
        FROM
        sys_menu t1
        LEFT JOIN sys_role_menu t2 ON t1.id = t2.menu_id
        LEFT JOIN sys_role t3 ON t2.role_id = t3.id
        WHERE
        t3.role_code IN
        <foreach collection="roles" item="role" open="(" separator="," close=")">
            #{role}
        </foreach>
    </select>

    <!--Ã¨Å½·Ã¥â€“Ã¥½â€œÃ¥â€°Ã§â€¨Ã¦Ë†·Ã§Å¡â€žÃ¦Å’â€°eâ€™®Ã¦Æ’eâ„¢-->
    <select id="getPermission" resultType="java.lang.String">
        SELECT
            t1.permission
        FROM
            sys_menu t1
            LEFT JOIN sys_role_menu t2 ON t1.id = t2.menu_id
            LEFT JOIN sys_role t3 ON t2.role_id = t3.id
        WHERE
                t3.role_code IN
            <foreach collection="roles" item="role" open="(" separator="," close=")">
                #{role}
            </foreach>
    </select>

</mapper>
